{% extends "base.html" %}

{% block page_title %}Master Control • Juju FX{% endblock %}

{% block content %}
<!-- Loading Overlay -->
<div id="loading-overlay" class="loading-overlay hidden">
    <div class="loading-content">
        <div class="spinner-ring"></div>
        <p>Loading...</p>
    </div>
</div>

<!-- Main Dashboard -->
<div class="dashboard-container">
    <!-- Header -->
    <div class="dashboard-header">
        <div class="header-left">
            <h1><i class="fas fa-crown"></i> Master Control Center</h1>
            <span class="badge badge-admin">Admin Mode</span>
        </div>
        <div class="header-right">
            <div class="level-indicator">
                <span class="label">Current Level</span>
                <span class="value" id="header-level">{{ current_level }}</span>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon blue">
                <i class="fas fa-robot"></i>
            </div>
            <div class="stat-content">
                <span class="stat-label">Active EAs</span>
                <span class="stat-value" id="stat-eas">0</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="stat-content">
                <span class="stat-label">Today's P&L</span>
                <span class="stat-value" id="stat-pnl">R 0</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon purple">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <span class="stat-label">Active Users</span>
                <span class="stat-value" id="stat-users">0</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange">
                <i class="fas fa-coins"></i>
            </div>
            <div class="stat-content">
                <span class="stat-label">Commission</span>
                <span class="stat-value" id="stat-commission">R 0</span>
            </div>
        </div>
    </div>

    <!-- Risk Management Center -->
    <div class="risk-section">
        <div class="section-header">
            <h2><i class="fas fa-shield-alt"></i> Risk Management Center</h2>
            <span class="live-badge">LIVE</span>
        </div>
        
        <div class="risk-card">
            <div class="current-level-display">
                <div class="level-number" id="current-level-big">{{ current_level }}</div>
                <div class="level-label" id="current-level-name">ACTIVE</div>
                <div class="level-source" id="level-source">
                    <i class="fas fa-check-circle text-success"></i>
                    <span>MT5 Connected</span>
                </div>
            </div>
            
            <div class="level-slider-container">
                <div class="slider-labels">
                    <span>SAFE</span>
                    <span>MODERATE</span>
                    <span>AGGRESSIVE</span>
                </div>
                
                <input type="range" 
                       id="level-slider" 
                       class="level-slider" 
                       min="0" 
                       max="6" 
                       value="{{ current_level }}"
                       oninput="previewLevel(this.value)">
                
                <div class="slider-marks">
                    <span>0</span><span>1</span><span>2</span><span>3</span><span>4</span><span>5</span><span>6</span>
                </div>
            </div>
            
            <div class="level-buttons">
                <button class="level-btn" data-level="0" onclick="setLevel(0)">HOLD</button>
                <button class="level-btn" data-level="1" onclick="setLevel(1)">LOW</button>
                <button class="level-btn" data-level="2" onclick="setLevel(2)">CAUTIOUS</button>
                <button class="level-btn" data-level="3" onclick="setLevel(3)">BALANCED</button>
                <button class="level-btn" data-level="4" onclick="setLevel(4)">GROWTH</button>
                <button class="level-btn" data-level="5" onclick="setLevel(5)">ACTIVE</button>
                <button class="level-btn" data-level="6" onclick="setLevel(6)">MAX</button>
            </div>
            
            <div class="risk-info">
                <div class="info-item">
                    <i class="fas fa-info-circle"></i>
                    <span id="level-description">Level 0: No new positions</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-server"></i>
                    <span id="proxy-status">Proxy: Checking...</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-plug"></i>
                    <span id="mt5-status">MT5: Disconnected</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Two Column Layout -->
    <div class="two-column">
        <!-- Left Column - EA Performance -->
        <div class="column">
            <div class="section-header">
                <h2><i class="fas fa-robot"></i> EA Performance</h2>
                <button class="btn-refresh" onclick="loadEAData()">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
            
            <div class="ea-grid" id="ea-grid">
                <div class="loading-spinner">Loading EAs...</div>
            </div>
        </div>
        
        <!-- Right Column - Level Performance -->
        <div class="column">
            <div class="section-header">
                <h2><i class="fas fa-layer-group"></i> Level Performance</h2>
                <span class="badge">P&L by Level</span>
            </div>
            
            <div class="level-stats" id="level-stats">
                <div class="loading-spinner">Loading levels...</div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="activity-section">
        <div class="section-header">
            <h2><i class="fas fa-history"></i> Recent Trading Activity</h2>
            <div class="filter-group">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="win">Wins</button>
                <button class="filter-btn" data-filter="loss">Losses</button>
            </div>
        </div>
        
        <div class="table-container">
            <table class="trades-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Symbol</th>
                        <th>Type</th>
                        <th>Volume</th>
                        <th>Level</th>
                        <th>P&L (ZAR)</th>
                    </tr>
                </thead>
                <tbody id="recent-trades">
                    <tr>
                        <td colspan="6" class="text-center">Loading trades...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
:root {
    --bg-primary: #0f172a;
    --bg-secondary: #1e293b;
    --bg-tertiary: #334155;
    --text-primary: #f8fafc;
    --text-secondary: #94a3b8;
    --accent-primary: #3b82f6;
    --accent-secondary: #8b5cf6;
    --success: #10b981;
    --danger: #ef4444;
    --warning: #f59e0b;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
}

.dashboard-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px;
}

/* Header */
.dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding: 20px;
    background: linear-gradient(135deg, var(--bg-secondary), #2d3748);
    border-radius: 16px;
    border: 1px solid rgba(59,130,246,0.2);
}

.header-left {
    display: flex;
    align-items: center;
    gap: 16px;
}

.header-left h1 {
    font-size: 24px;
    font-weight: 600;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.badge-admin {
    background: var(--accent-primary);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.level-indicator {
    text-align: right;
}

.level-indicator .label {
    display: block;
    font-size: 12px;
    color: var(--text-secondary);
}

.level-indicator .value {
    font-size: 32px;
    font-weight: 700;
    color: var(--accent-primary);
    font-family: monospace;
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: var(--bg-secondary);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    border: 1px solid var(--bg-tertiary);
    transition: all 0.2s;
}

.stat-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent-primary);
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
}

.stat-icon.blue { background: rgba(59,130,246,0.2); color: #3b82f6; }
.stat-icon.green { background: rgba(16,185,129,0.2); color: #10b981; }
.stat-icon.purple { background: rgba(139,92,246,0.2); color: #8b5cf6; }
.stat-icon.orange { background: rgba(245,158,11,0.2); color: #f59e0b; }

.stat-content {
    flex: 1;
}

.stat-label {
    display: block;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 4px;
}

.stat-value {
    display: block;
    font-size: 24px;
    font-weight: 700;
}

/* Risk Section */
.risk-section {
    margin-bottom: 30px;
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}

.section-header h2 {
    font-size: 18px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
}

.live-badge {
    background: rgba(16,185,129,0.2);
    color: #10b981;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    animation: pulse 2s infinite;
}

.risk-card {
    background: linear-gradient(135deg, var(--bg-secondary), #2d3748);
    border-radius: 24px;
    padding: 30px;
    border: 2px solid rgba(59,130,246,0.3);
}

.current-level-display {
    text-align: center;
    margin-bottom: 30px;
}

.level-number {
    font-size: 72px;
    font-weight: 800;
    color: var(--accent-primary);
    line-height: 1;
    font-family: monospace;
    text-shadow: 0 0 20px rgba(59,130,246,0.5);
}

.level-label {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
    margin: 8px 0;
}

.level-source {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 12px;
}

.level-slider-container {
    margin: 30px 0;
}

.slider-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
}

.level-slider {
    width: 100%;
    height: 8px;
    border-radius: 4px;
    background: linear-gradient(90deg, #3b82f6, #10b981, #f59e0b, #ef4444);
    -webkit-appearance: none;
    margin: 20px 0;
}

.level-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: white;
    border: 3px solid var(--accent-primary);
    cursor: pointer;
    box-shadow: 0 0 20px var(--accent-primary);
}

.slider-marks {
    display: flex;
    justify-content: space-between;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    padding: 0 8px;
}

.level-buttons {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    margin: 30px 0;
}

.level-btn {
    padding: 12px 8px;
    background: var(--bg-tertiary);
    border: 1px solid var(--bg-tertiary);
    color: var(--text-secondary);
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.level-btn:hover {
    border-color: var(--accent-primary);
    transform: translateY(-2px);
}

.level-btn.active {
    background: var(--accent-primary);
    color: white;
    border-color: var(--accent-primary);
}

.level-btn.loading {
    opacity: 0.5;
    pointer-events: none;
    position: relative;
}

.level-btn.loading::after {
    content: '';
    position: absolute;
    width: 16px;
    height: 16px;
    top: 50%;
    left: 50%;
    margin: -8px 0 0 -8px;
    border: 2px solid transparent;
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

.risk-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 20px;
    border-top: 1px solid var(--bg-tertiary);
}

.info-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-secondary);
}

/* Two Column Layout */
.two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
}

.column {
    background: var(--bg-secondary);
    border-radius: 16px;
    padding: 20px;
    border: 1px solid var(--bg-tertiary);
}

.btn-refresh {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--bg-tertiary);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
}

.btn-refresh:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
    transform: rotate(180deg);
}

/* EA Grid */
.ea-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
    max-height: 400px;
    overflow-y: auto;
    padding: 4px;
}

.ea-card {
    background: var(--bg-tertiary);
    border-radius: 12px;
    padding: 16px;
    border-left: 4px solid transparent;
    transition: all 0.2s;
}

.ea-card.running { border-left-color: var(--success); }
.ea-card.paused { border-left-color: var(--warning); }
.ea-card.error { border-left-color: var(--danger); }

.ea-symbol {
    font-weight: 600;
    margin-bottom: 8px;
}

.ea-profit {
    font-family: monospace;
    font-weight: 600;
    margin: 8px 0;
}

.ea-profit.positive { color: var(--success); }
.ea-profit.negative { color: var(--danger); }

.ea-level {
    display: inline-block;
    padding: 4px 8px;
    background: var(--accent-primary);
    color: white;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
}

/* Level Stats */
.level-stats {
    max-height: 400px;
    overflow-y: auto;
}

.level-stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    border-bottom: 1px solid var(--bg-tertiary);
}

.level-stat-info {
    flex: 1;
}

.level-stat-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 4px;
}

.level-stat-bar {
    height: 4px;
    background: var(--bg-tertiary);
    border-radius: 2px;
    overflow: hidden;
}

.level-stat-fill {
    height: 100%;
    transition: width 0.3s;
}

.level-stat-fill.positive { background: var(--success); }
.level-stat-fill.negative { background: var(--danger); }

.level-stat-value {
    font-family: monospace;
    font-weight: 600;
}

/* Activity Section */
.activity-section {
    background: var(--bg-secondary);
    border-radius: 16px;
    padding: 20px;
    border: 1px solid var(--bg-tertiary);
}

.filter-group {
    display: flex;
    gap: 8px;
    background: var(--bg-tertiary);
    padding: 4px;
    border-radius: 8px;
}

.filter-btn {
    padding: 6px 12px;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    transition: all 0.2s;
}

.filter-btn.active {
    background: var(--accent-primary);
    color: white;
}

.table-container {
    overflow-x: auto;
    margin-top: 16px;
}

.trades-table {
    width: 100%;
    border-collapse: collapse;
}

.trades-table th {
    text-align: left;
    padding: 12px;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    border-bottom: 1px solid var(--bg-tertiary);
}

.trades-table td {
    padding: 12px;
    border-bottom: 1px solid var(--bg-tertiary);
    font-size: 14px;
}

.trades-table tr.win { border-left: 3px solid var(--success); }
.trades-table tr.loss { border-left: 3px solid var(--danger); }

.text-center { text-align: center; }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }

.loading-spinner {
    text-align: center;
    padding: 40px;
    color: var(--text-secondary);
}

.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15,23,42,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: all 0.3s;
}

.loading-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.spinner-ring {
    width: 60px;
    height: 60px;
    border: 4px solid transparent;
    border-top-color: var(--accent-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}
</style>
{% endblock %}

{% block scripts %}
<script>
// CSRF Token
const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    loadEAData();
    loadLevelStats();
    loadRecentTrades();
    checkConnections();
    initLevelUI();
});

function initLevelUI() {
    const currentLevel = {{ current_level }};
    updateLevelUI(currentLevel);
    document.getElementById('level-slider').value = currentLevel;
}

function previewLevel(level) {
    document.querySelectorAll('.level-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.level) === parseInt(level));
    });
    
    const descriptions = {
        0: 'Level 0: No new positions - Safe mode',
        1: 'Level 1: Low risk - Minimum lot sizes',
        2: 'Level 2: Cautious - Reduced exposure',
        3: 'Level 3: Balanced - Normal trading',
        4: 'Level 4: Growth - Increased positions',
        5: 'Level 5: Active - Aggressive entries',
        6: 'Level 6: Maximum - Full lot sizes'
    };
    document.getElementById('level-description').textContent = descriptions[level] || descriptions[0];
}

function setLevel(level) {
    const btn = document.querySelector(`.level-btn[data-level="${level}"]`);
    btn.classList.add('loading');
    
    fetch('/api/ea/commander/level', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
        },
        body: JSON.stringify({level: level})
    })
    .then(response => response.json())
    .then(data => {
        btn.classList.remove('loading');
        if (data.success) {
            updateLevelUI(level);
            document.getElementById('level-slider').value = level;
            showToast('success', `Level ${level} activated`);
        } else {
            showToast('error', data.error || 'Failed to update level');
        }
    })
    .catch(error => {
        btn.classList.remove('loading');
        showToast('error', 'Failed to update risk level');
        console.error(error);
    });
}

function updateLevelUI(level) {
    document.getElementById('current-level-big').textContent = level;
    document.getElementById('header-level').textContent = level;
    
    const labels = ['HOLD', 'LOW', 'CAUTIOUS', 'BALANCED', 'GROWTH', 'ACTIVE', 'MAX'];
    document.getElementById('current-level-name').textContent = labels[level] || 'ACTIVE';
    
    document.querySelectorAll('.level-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.level) === level);
    });
}

function loadEAData() {
    fetch('/api/ea/instances', {
        headers: { 'X-CSRF-Token': csrfToken }
    })
    .then(response => response.json())
    .then(data => {
        const grid = document.getElementById('ea-grid');
        if (data.eas && data.eas.length) {
            grid.innerHTML = data.eas.map(ea => `
                <div class="ea-card ${ea.status}">
                    <div class="ea-symbol">${ea.symbol}</div>
                    <div class="ea-profit ${ea.total_profit_zar >= 0 ? 'positive' : 'negative'}">
                        R ${ea.total_profit_zar?.toFixed(2) || 0}
                    </div>
                    <div class="ea-stats">
                        <small>Trades: ${ea.total_trades || 0}</small>
                        <small>WR: ${ea.win_rate || 0}%</small>
                    </div>
                    <span class="ea-level">L${ea.current_level || 0}</span>
                </div>
            `).join('');
        } else {
            grid.innerHTML = '<div class="loading-spinner">No EAs connected</div>';
        }
    })
    .catch(() => {
        document.getElementById('ea-grid').innerHTML = '<div class="loading-spinner">Failed to load EAs</div>';
    });
}

function loadLevelStats() {
    fetch('/api/performance/levels', {
        headers: { 'X-CSRF-Token': csrfToken }
    })
    .then(response => response.json())
    .then(data => {
        const container = document.getElementById('level-stats');
        const levels = data.levels || {};
        const maxPnl = Math.max(...Object.values(levels).map(l => Math.abs(l.zar || 0)), 1);
        
        container.innerHTML = Object.entries(levels).map(([level, stats]) => {
            const pnl = stats.zar || 0;
            const percentage = (Math.abs(pnl) / maxPnl) * 100;
            const isPositive = pnl >= 0;
            
            return `
                <div class="level-stat-item">
                    <div class="level-stat-info">
                        <div class="level-stat-header">
                            <span>Level ${level}</span>
                            <span>${stats.trades || 0} trades</span>
                        </div>
                        <div class="level-stat-bar">
                            <div class="level-stat-fill ${isPositive ? 'positive' : 'negative'}" 
                                 style="width: ${percentage}%"></div>
                        </div>
                    </div>
                    <div class="level-stat-value ${isPositive ? 'text-success' : 'text-danger'}">
                        R ${pnl.toFixed(2)}
                    </div>
                </div>
            `;
        }).join('');
    });
}

function loadRecentTrades() {
    fetch('/api/trades/recent', {
        headers: { 'X-CSRF-Token': csrfToken }
    })
    .then(response => response.json())
    .then(data => {
        const tbody = document.getElementById('recent-trades');
        const trades = data.trades || [];
        
        if (trades.length) {
            tbody.innerHTML = trades.map(t => `
                <tr class="${t.profit_zar >= 0 ? 'win' : 'loss'}">
                    <td>${t.formatted_time || 'N/A'}</td>
                    <td>${t.symbol || 'Unknown'}</td>
                    <td><span class="badge ${t.type}">${t.type || 'N/A'}</span></td>
                    <td>${t.volume || 0}</td>
                    <td>L${t.level || 0}</td>
                    <td class="${t.profit_zar >= 0 ? 'text-success' : 'text-danger'}">
                        R ${t.profit_zar?.toFixed(2) || 0}
                    </td>
                </tr>
            `).join('');
        } else {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center">No recent trades</td></tr>';
        }
    });
}

function checkConnections() {
    fetch('/api/mt5-bridge/health', {
        headers: { 'X-CSRF-Token': csrfToken }
    })
    .then(response => response.json())
    .then(data => {
        const mt5Status = document.getElementById('mt5-status');
        const proxyStatus = document.getElementById('proxy-status');
        
        if (data.status === 'connected') {
            mt5Status.innerHTML = '<i class="fas fa-check-circle text-success"></i> MT5: Connected';
            proxyStatus.innerHTML = '<i class="fas fa-check-circle text-success"></i> Proxy: Connected';
        } else {
            mt5Status.innerHTML = '<i class="fas fa-times-circle text-danger"></i> MT5: Disconnected';
            proxyStatus.innerHTML = '<i class="fas fa-times-circle text-danger"></i> Proxy: Disconnected';
        }
    })
    .catch(() => {
        document.getElementById('mt5-status').innerHTML = '<i class="fas fa-times-circle text-danger"></i> MT5: Disconnected';
        document.getElementById('proxy-status').innerHTML = '<i class="fas fa-times-circle text-danger"></i> Proxy: Disconnected';
    });
}

function showToast(type, message) {
    // You can implement a toast notification here
    console.log(`${type}: ${message}`);
    alert(message); // Temporary alert for debugging
}

// Refresh data periodically
setInterval(loadEAData, 30000);
setInterval(loadLevelStats, 30000);
setInterval(loadRecentTrades, 30000);
setInterval(checkConnections, 10000);
</script>
{% endblock %}
